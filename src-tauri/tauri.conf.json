{
  "$schema": "https://raw.githubusercontent.com/nicedoc/schemas/main/tauri/config.schema.json",
  "productName": "ripNotepad++",
  "version": "0.1.0",
  "identifier": "com.ripnotepad.plusplus",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "ripNotepad++ - new file",
        "width": 1024,
        "height": 700,
        "minWidth": 400,
        "minHeight": 300,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png"
    ],
    "fileAssociations": [
      {
        "ext": ["txt", "md", "json", "xml", "html", "css", "js", "ts", "py", "rs", "go", "java", "c", "cpp", "h", "yaml", "yml", "toml", "ini", "cfg", "log", "csv"],
        "name": "Text Document",
        "description": "Text file"
      },
      {
        "ext": ["jsx", "tsx", "vue", "svelte"],
        "name": "Source Code",
        "description": "Source code file"
      }
    ]
  }
}
